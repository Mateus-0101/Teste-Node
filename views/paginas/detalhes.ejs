<html lang="pt-br">
    <%- include('../parciais/head.ejs') %>

    <body>
        <%- include ('../parciais/nav.ejs') %>

        <div class="Detalhes do Conteúdo">
            <h2><%= conteudo.titulo %></h2>
            <div class="conteudo">
                <p><%= conteudo.corpo %></p>
            </div>
            <a class="delete" data-doc="<%= conteudo._id %>">
                Apagar
            </a>
        </div>
    </body>
    <%- include('../parciais/footer.ejs') %>

    <script>
        const lixeira = document.querySelector('a.delete');

        lixeira.addEventListener('click', (e) => {
            const endpoint = `/conteudo/${lixeira.dataset.doc}`;

            fetch(endpoint, {
                method: 'DELETE'
            })
            .then((response) => response.json())
            .then((data) => window.location.href = data.redirect)
            .catch(err => console.log(err));
        });
    </script>
</html>